{
  "name": "@agconn/sms",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./worker": {
      "source": "./src/worker.ts",
      "import": "./dist/worker.js",
      "types": "./src/worker.ts"
    },
    "./templates": {
      "source": "./src/templates/index.ts",
      "import": "./dist/templates/index.js",
      "types": "./src/templates/index.ts"
    },
    "./inbound-number": {
      "source": "./src/inbound-number.ts",
      "import": "./dist/inbound-number.js",
      "types": "./src/inbound-number.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agconn/audit": "workspace:*",
    "@agconn/db": "workspace:*",
    "luxon": "3.5.0",
    "pg-boss": "12.18.1",
    "twilio": "6.0.0"
  },
  "devDependencies": {
    "@types/luxon": "3.4.2",
    "@types/node": "^22.10.0",
    "typescript": "6.0.3"
  }
}
