{
  "name": "@agconn/email",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./tokens": {
      "source": "./src/tokens.ts",
      "import": "./dist/tokens.js",
      "types": "./src/tokens.ts"
    },
    "./strings/waitlist": {
      "source": "./src/strings/waitlist.ts",
      "import": "./dist/strings/waitlist.js",
      "types": "./src/strings/waitlist.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "email:dev": "email dev --dir ./src/templates",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agconn/db": "workspace:*",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.8",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "resend": "6.12.2",
    "jose": "6.2.3",
    "pg-boss": "12.18.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "react-email": "6.0.5",
    "typescript": "6.0.3"
  }
}
