// Edit-Job v2 — lookup tables, photos, screening, edit events, SMS routing
// ============================================================================

model Crop {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  labelEn   String   @map("label_en")
  labelEs   String   @map("label_es")
  glyphKey  String   @map("glyph_key")
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  jobPostings JobPosting[]

  @@index([active, sortOrder])
  @@map("crops")
}

model RoleType {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  labelEn   String   @map("label_en")
  labelEs   String   @map("label_es")
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  jobPostings JobPosting[]

  @@index([active, sortOrder])
  @@map("role_types")
}

model SkillTag {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  labelEn   String   @map("label_en")
  labelEs   String   @map("label_es")
  category  String   @default("general")
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([active, sortOrder])
  @@index([category])
  @@map("skill_tags")
}

model EmployerContact {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  employerId String    @map("employer_id") @db.Uuid
  name       String
  phone      String
  role       String    @default("foreman")
  languages  String[]  @default(["en", "es"])
  sortOrder  Int       @default(0) @map("sort_order")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  employer    EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  jobPostings JobPosting[]

  @@index([tenantId])
  @@index([employerId])
  @@map("employer_contacts")
}

model JobPhoto {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  jobId        String   @map("job_id") @db.Uuid
  url          String
  storageKey   String   @map("storage_key")
  captionEn    String?  @map("caption_en")
  captionEs    String?  @map("caption_es")
  width        Int?
  height       Int?
  sortOrder    Int      @default(0) @map("sort_order")
  uploadedById String?  @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  job        JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)
  uploadedBy User?      @relation(fields: [uploadedById], references: [id])

  @@index([tenantId])
  @@index([jobId, sortOrder])
  @@map("job_photos")
}

model JobScreeningQuestion {
  id         String              @id @default(uuid()) @db.Uuid
  tenantId   String              @map("tenant_id") @db.Uuid
  jobId      String              @map("job_id") @db.Uuid
  sortOrder  Int                 @default(0) @map("sort_order")
  questionEn String              @map("question_en")
  questionEs String              @map("question_es")
  answerType ScreeningAnswerType @default(yes_no) @map("answer_type")
  required   Boolean             @default(true)
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  tenant  Tenant                       @relation(fields: [tenantId], references: [id])
  job     JobPosting                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  answers ApplicationScreeningAnswer[]

  @@index([tenantId])
  @@index([jobId, sortOrder])
  @@map("job_screening_questions")
}

model ApplicationScreeningAnswer {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  applicationId String   @map("application_id") @db.Uuid
  questionId    String   @map("question_id") @db.Uuid
  answerYes     Boolean? @map("answer_yes")
  answerText    String?  @map("answer_text")
  answeredAt    DateTime @default(now()) @map("answered_at")

  tenant      Tenant               @relation(fields: [tenantId], references: [id])
  application Application          @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  question    JobScreeningQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([applicationId, questionId])
  @@index([tenantId])
  @@map("application_screening_answers")
}

model JobEditEvent {
  id                   String           @id @default(uuid()) @db.Uuid
  tenantId             String           @map("tenant_id") @db.Uuid
  jobId                String           @map("job_id") @db.Uuid
  actorUserId          String           @map("actor_user_id")
  kind                 JobEditEventKind
  fieldPath            String?          @map("field_path")
  before               Json             @default("{}")
  after                Json             @default("{}")
  renotifyDispatchedAt DateTime?        @map("renotify_dispatched_at")
  createdAt            DateTime         @default(now()) @map("created_at")

  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  job             JobPosting          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  actor           User                @relation(fields: [actorUserId], references: [id])
  renotifications JobRenotification[]

  @@index([tenantId])
  @@index([jobId, createdAt])
  @@map("job_edit_events")
}

model JobRenotification {
  id            String          @id @default(uuid()) @db.Uuid
  tenantId      String          @map("tenant_id") @db.Uuid
  jobId         String          @map("job_id") @db.Uuid
  editEventId   String          @map("edit_event_id") @db.Uuid
  applicationId String          @map("application_id") @db.Uuid
  channel       RenotifyChannel
  status        RenotifyStatus  @default(queued)
  sentAt        DateTime?       @map("sent_at")
  error         String?

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  job         JobPosting   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  editEvent   JobEditEvent @relation(fields: [editEventId], references: [id], onDelete: Cascade)
  application Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([editEventId, applicationId, channel])
  @@index([tenantId])
  @@index([jobId])
  @@map("job_renotifications")
}

model SmsKeyword {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  keyword    String
  kind       String
  entityId   String    @map("entity_id") @db.Uuid
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([kind, entityId])
  @@map("sms_keywords")
}

// One row per admin-generated grant report (placement, training, employer).
// Used for compliance audit ("show me every export of placement data in 2026").
// Admin-only; tenantId nullable so cross-tenant exports are representable.
// See docs/30-admin/02-placement-report/02-data-model.md.
model ReportRun {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid
  reportType  String   @map("report_type")
  filters     Json
  rowCount    Int      @map("row_count")
  format      String
  generatedBy String   @map("generated_by")
  generatedAt DateTime @default(now()) @map("generated_at")
  blobPath    String?  @map("blob_path")

  @@index([reportType, generatedAt])
  @@index([tenantId, generatedAt])
  @@map("report_runs")
}
