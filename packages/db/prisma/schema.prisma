model Tenant {
  id        String    @id @default(uuid()) @db.Uuid
  slug      String    @unique
  name      String
  settings  Json      @default("{}")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  waitlist                    Waitlist[]
  emailLogs                   EmailLog[]
  auditEvents                 AuditEvent[]
  users                       User[]
  employerProfiles            EmployerProfile[]
  authEvents                  AuthEvent[]
  smsLogs                     SmsLog[]
  jobPostings                 JobPosting[]
  applications                Application[]
  applicationEvents           ApplicationEvent[]
  trainingPrograms            TrainingProgram[]
  enrollments                 Enrollment[]
  verificationLogs            VerificationLog[]
  workerInvitations           WorkerInvitation[]
  workerSearchLogs            WorkerSearchLog[]
  billingEvents               BillingEvent[]
  crews                       Crew[]
  crewMembers                 CrewMember[]
  shifts                      Shift[]
  shiftAssignments            ShiftAssignment[]
  payrollPeriods              PayrollPeriod[]
  payrollLines                PayrollLine[]
  complianceItems             ComplianceItem[]
  complianceScoreSnapshots    ComplianceScoreSnapshot[]
  conversations               Conversation[]
  conversationParticipants    ConversationParticipant[]
  messages                    Message[]
  translationKeys             TranslationKey[]
  employerContacts            EmployerContact[]
  jobPhotos                   JobPhoto[]
  jobScreeningQuestions       JobScreeningQuestion[]
  applicationScreeningAnswers ApplicationScreeningAnswer[]
  jobEditEvents               JobEditEvent[]
  jobRenotifications          JobRenotification[]
  smsKeywords                 SmsKeyword[]

  @@map("tenants")
}

model Waitlist {
  id             String            @id @default(uuid()) @db.Uuid
  tenantId       String?           @map("tenant_id") @db.Uuid
  email          String?
  phone          String?
  county         String?
  preferredLang  Lang              @default(es) @map("preferred_lang")
  audience       WaitlistAudience?
  source         WaitlistSource    @default(landing_final_cta)
  confirmedAt    DateTime?         @map("confirmed_at")
  welcomedAt     DateTime?         @map("welcomed_at")
  unsubscribedAt DateTime?         @map("unsubscribed_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([phone])
  @@index([county])
  @@map("waitlist")
}

model EmailLog {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String?     @map("tenant_id") @db.Uuid
  template     String
  locale       Lang
  toEmail      String      @map("to_email")
  fromEmail    String      @map("from_email")
  subject      String
  status       EmailStatus @default(queued)
  providerId   String?     @unique @map("provider_id")
  errorMsg     String?     @map("error_msg")
  refType      String?     @map("ref_type")
  refId        String?     @map("ref_id")
  queuedAt     DateTime    @default(now()) @map("queued_at")
  sentAt       DateTime?   @map("sent_at")
  deliveredAt  DateTime?   @map("delivered_at")
  bouncedAt    DateTime?   @map("bounced_at")
  complainedAt DateTime?   @map("complained_at")
  failedAt     DateTime?   @map("failed_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([toEmail])
  @@index([template, queuedAt])
  @@index([status])
  @@index([refType, refId])
  @@map("email_log")
}

model EmailSuppression {
  email        String            @id
  reason       SuppressionReason
  suppressedAt DateTime          @default(now()) @map("suppressed_at")
  source       String            @default("system")

  @@map("email_suppression")
}

// Audit log — append-only, HMAC-tamper-evident, monthly partitioned. RLS,
// roles, and the partitioning trigger live alongside the migration SQL since
// Prisma doesn't model PARTITION BY or per-policy RLS natively.
//
// The id column is intentionally non-PK in the schema (the underlying table
// is PARTITION BY RANGE on occurred_at, with a compound PK (id, occurred_at)).
// Prisma needs a single-field id, so we annotate id with @id but the
// migration replaces the PK with the compound version.
model AuditEvent {
  id             BigInt       @id @default(autoincrement())
  tenantId       String       @map("tenant_id") @db.Uuid
  occurredAt     DateTime     @default(now()) @map("occurred_at") @db.Timestamptz
  actorType      ActorType    @map("actor_type")
  actorId        String?      @map("actor_id")
  actorRole      String?      @map("actor_role")
  actorIp        String?      @map("actor_ip") @db.Inet
  actorUserAgent String?      @map("actor_user_agent")
  action         String
  resourceType   String?      @map("resource_type")
  resourceId     String?      @map("resource_id")
  outcome        AuditOutcome @default(success)
  correlationId  String?      @map("correlation_id") @db.Uuid
  metadata       Json         @default("{}")
  eventHmac      Bytes        @map("event_hmac")
  eventHmacV     Int          @default(1) @map("event_hmac_v") @db.SmallInt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, occurredAt(sort: Desc)])
  @@index([tenantId, actorId, occurredAt(sort: Desc)])
  @@index([tenantId, resourceType, resourceId])
  @@index([tenantId, action, occurredAt(sort: Desc)])
  @@index([correlationId])
  @@map("audit_events")
}

// User mirror of Clerk identity. id == Clerk userId. Mirror fields are kept
// in sync via webhooks (services/api/src/webhooks/clerk.ts). PII like phone
// + email is stored here too for joins; Clerk remains the source of truth.
model User {
  id            String   @id // matches Clerk userId
  tenantId      String?  @map("tenant_id") @db.Uuid
  role          UserRole
  permissions   String[] @default([]) // fine-grained scopes within role; '*' = wildcard
  preferredLang Lang     @default(es) @map("preferred_lang")
  email         String?
  phone         String?
  onboarded     Boolean  @default(false)
  // SMS A2P consent provenance for Twilio 10DLC dispute traceability.
  //   consentMethod  — 'web_otp' (signed up at agconn.com, verified phone
  //                    OTP) or 'sms_double_opt_in' (texted an opt-in keyword
  //                    to the published number, replied YES to the
  //                    confirmation prompt). NULL for non-worker roles and
  //                    legacy users predating consent capture.
  //   consentedAt    — Timestamp when the user completed the consent flow.
  //   smsOptInState  — 'pending_confirm' (stub created from inbound keyword,
  //                    awaiting YES) or 'consented' (confirmed). NULL for
  //                    users that never went through the SMS opt-in flow.
  // See docs/00-foundation/05-sms-pipeline/ and the Twilio A2P 10DLC campaign
  // registration.
  consentMethod String?   @map("consent_method")
  consentedAt   DateTime? @map("consented_at")
  smsOptInState String?   @map("sms_opt_in_state")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant                     Tenant?                   @relation(fields: [tenantId], references: [id])
  employerProfile            EmployerProfile?
  workerProfile              WorkerProfile?
  applications               Application[]
  savedSearches              SavedSearch[]
  enrollments                Enrollment[]
  trainingPrograms           TrainingProgram[]         @relation("TrainingProgramOrg")
  jobPostings                JobPosting[]              @relation("JobPostingEmployer")
  jobPostingsEdited          JobPosting[]              @relation("JobPostingLastEditor")
  jobEditEvents              JobEditEvent[]
  jobPhotosUploaded          JobPhoto[]
  workerInvitations          WorkerInvitation[]        @relation("WorkerInvitationWorker")
  crewsOwned                 Crew[]                    @relation("CrewEmployer")
  crewsLed                   Crew[]                    @relation("CrewForeman")
  crewMemberships            CrewMember[]
  shiftsOwned                Shift[]                   @relation("ShiftEmployer")
  shiftAssignments           ShiftAssignment[]
  payrollOwned               PayrollPeriod[]           @relation("PayrollEmployer")
  payrollApproved            PayrollPeriod[]           @relation("PayrollApprover")
  payrollLines               PayrollLine[]
  complianceItems            ComplianceItem[]          @relation("ComplianceEmployer")
  conversationsOwned         Conversation[]            @relation("ConversationEmployer")
  conversationParticipations ConversationParticipant[]
  messagesSent               Message[]

  @@index([tenantId])
  @@index([phone])
  @@index([email])
  @@map("users")
}

// One per Clerk Organization that maps to an employer (vs tenant orgs).
// FLC verification, plan tier, and Stripe subscription state live here.
// See docs/20-employer/01-flc-verification/02-data-model.md and 05-subscription-billing/02-data-model.md.
model EmployerProfile {
  id                      String            @id @default(uuid()) @db.Uuid
  userId                  String            @unique @map("user_id")
  tenantId                String            @map("tenant_id") @db.Uuid
  clerkOrgId              String?           @unique @map("clerk_org_id")
  legalName               String            @map("legal_name")
  dbaName                 String?           @map("dba_name")
  contactEmail            String?           @map("contact_email")
  contactPhone            String?           @map("contact_phone")
  licenseType             LicenseType?      @map("license_type")
  ein                     String?
  flcLicenseNum           String?           @map("flc_license_num")
  dolMspaNum              String?           @map("dol_mspa_num")
  county                  County?
  streetAddress           String?           @map("street_address")
  city                    String?
  stateCode               String?           @map("state_code")
  postalCode              String?           @map("postal_code")
  addressLat              Decimal?          @map("address_lat") @db.Decimal(9, 6)
  addressLng              Decimal?          @map("address_lng") @db.Decimal(9, 6)
  mapboxId                String?           @map("mapbox_id")
  flcVerifiedAt           DateTime?         @map("flc_verified_at")
  flcLastCheckedAt        DateTime?         @map("flc_last_checked_at")
  flcCheckStatus          FlcCheckStatus?   @map("flc_check_status")
  flcExpiresAt            DateTime?         @map("flc_expires_at") @db.Date
  flcLegalNameOnRecord    String?           @map("flc_legal_name_on_record")
  mspaVerifiedAt          DateTime?         @map("mspa_verified_at")
  mspaExpiresAt           DateTime?         @map("mspa_expires_at") @db.Date
  mspaAuthHousing         Boolean?          @map("mspa_auth_housing")
  mspaAuthTransport       Boolean?          @map("mspa_auth_transport")
  mspaAuthDriving         Boolean?          @map("mspa_auth_driving")
  verifiedBy              String?           @map("verified_by")
  rejectedAt              DateTime?         @map("rejected_at")
  rejectionReason         String?           @map("rejection_reason")
  signatureName           String?           @map("signature_name")
  signatureTitle          String?           @map("signature_title")
  signatureImageUrl       String?           @map("signature_image_url")
  stripeCustomer          String?           @unique @map("stripe_customer")
  stripeSubId             String?           @map("stripe_sub_id")
  plan                    EmployerPlanTier  @default(free)
  planInterval            PlanInterval?     @map("plan_interval")
  planCurrentPeriodEnd    DateTime?         @map("plan_current_period_end")
  planCancelAtPeriodEnd   Boolean           @default(false) @map("plan_cancel_at_period_end")
  participatesInH2a       Boolean           @default(false) @map("participates_in_h2a")
  dolLastInspectionAt     DateTime?         @map("dol_last_inspection_at")
  dolLastInspectionResult InspectionResult? @map("dol_last_inspection_result")
  seoSlug                 String?           @unique @map("seo_slug")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")
  deletedAt               DateTime?         @map("deleted_at")

  user                     User                      @relation(fields: [userId], references: [id])
  tenant                   Tenant                    @relation(fields: [tenantId], references: [id])
  verificationLogs         VerificationLog[]
  workerInvitations        WorkerInvitation[]
  workerSearchLogs         WorkerSearchLog[]
  billingEvents            BillingEvent[]
  complianceScoreSnapshots ComplianceScoreSnapshot[]
  contacts                 EmployerContact[]

  @@index([tenantId])
  @@index([flcVerifiedAt])
  @@index([licenseType])
  @@index([flcLastCheckedAt])
  @@map("employer_profiles")
}

// Cached snapshot of the federal DOL/WHD MSPA Farm Labor Contractor registry,
// synced nightly from the data.gov bulk dataset. Platform-level reference data
// (no tenant_id) — every employer's MSPA verification is a local lookup against
// this table, avoiding per-onboarding outbound calls to dol.gov.
//
// See docs/20-employer/01-flc-verification/02-data-model.md.
model MspaFlcRegistry {
  id                String   @id @default(uuid()) @db.Uuid
  certificateNumber String   @unique @map("certificate_number")
  legalName         String   @map("legal_name")
  streetAddress     String?  @map("street_address")
  city              String?
  stateCode         String?  @map("state_code")
  postalCode        String?  @map("postal_code")
  expirationDate    DateTime @map("expiration_date") @db.Date
  authHousing       Boolean  @default(false) @map("auth_housing")
  authTransport     Boolean  @default(false) @map("auth_transport")
  authDriving       Boolean  @default(false) @map("auth_driving")
  syncedAt          DateTime @default(now()) @map("synced_at")
  removedAt         DateTime? @map("removed_at")

  @@index([legalName])
  @@index([syncedAt])
  @@map("mspa_flc_registry")
}

// One-row table that records the last successful MSPA dataset sync. Used by the
// scheduler to gate retries and by admins to surface "data freshness" to humans.
model MspaSyncRun {
  id              String   @id @default(uuid()) @db.Uuid
  startedAt       DateTime @default(now()) @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  status          String   @default("running")
  rowsAdded       Int      @default(0) @map("rows_added")
  rowsUpdated     Int      @default(0) @map("rows_updated")
  rowsRemoved     Int      @default(0) @map("rows_removed")
  sourceUrl       String?  @map("source_url")
  sourceUpdatedAt DateTime? @map("source_updated_at")
  errorMessage    String?  @map("error_message")

  @@index([startedAt])
  @@map("mspa_sync_run")
}

// Audit log for FLC / grower verification state changes.
// See docs/20-employer/01-flc-verification/02-data-model.md.
model VerificationLog {
  id          String             @id @default(uuid()) @db.Uuid
  tenantId    String             @map("tenant_id") @db.Uuid
  employerId  String             @map("employer_id") @db.Uuid
  action      VerificationAction
  actorUserId String             @map("actor_user_id")
  notes       String?
  payload     Json               @default("{}")
  createdAt   DateTime           @default(now()) @map("created_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  employer EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employerId, createdAt])
  @@map("verification_log")
}

// Per-search analytics + rate-limit basis for Pro+ employer worker search.
// See docs/20-employer/04-worker-search/02-data-model.md.
model WorkerSearchLog {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  employerId  String   @map("employer_id") @db.Uuid
  filters     Json
  resultCount Int      @map("result_count")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  employer EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([employerId, createdAt])
  @@map("worker_search_log")
}

// Pro+ employer invites a specific worker to apply to one of their postings.
// See docs/20-employer/04-worker-search/02-data-model.md.
model WorkerInvitation {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  employerId String    @map("employer_id") @db.Uuid
  workerId   String    @map("worker_id")
  jobId      String    @map("job_id") @db.Uuid
  message    String?   @db.VarChar(500)
  acceptedAt DateTime? @map("accepted_at")
  declinedAt DateTime? @map("declined_at")
  expiredAt  DateTime? @map("expired_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  employer EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  worker   User            @relation("WorkerInvitationWorker", fields: [workerId], references: [id])
  job      JobPosting      @relation(fields: [jobId], references: [id])

  @@unique([employerId, workerId, jobId])
  @@index([tenantId])
  @@index([workerId])
  @@map("worker_invitations")
}

// Append-only Stripe webhook event log. Idempotent on stripe_event_id.
// See docs/20-employer/05-subscription-billing/02-data-model.md.
model BillingEvent {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  employerId    String    @map("employer_id") @db.Uuid
  eventType     String    @map("event_type")
  stripeEventId String    @unique @map("stripe_event_id")
  payload       Json
  processedAt   DateTime? @map("processed_at")
  errorMsg      String?   @map("error_msg")
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  employer EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employerId, createdAt])
  @@map("billing_events")
}

// SMS log — append-only audit of every send attempt. RLS isolates by tenant
// for worker self-views; admin sees all. See migration sql for policies.
model SmsLog {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  userId      String?   @map("user_id")
  messageId   String?   @map("message_id") @db.Uuid
  template    String
  locale      Lang
  toPhone     String    @map("to_phone")
  body        String
  vars        Json      @default("{}")
  status      SmsStatus @default(queued)
  providerSid String?   @map("provider_sid")
  errorCode   String?   @map("error_code")
  optedOutAt  DateTime? @map("opted_out_at")
  queuedAt    DateTime  @default(now()) @map("queued_at")
  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  failedAt    DateTime? @map("failed_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([toPhone])
  @@index([messageId])
  @@index([template, queuedAt])
  @@index([status])
  @@map("sms_log")
}

// Phone-level opt-out cache (global, not tenant-scoped — STOP applies per
// FCC guidance to the phone number, not the account).
model SmsOptOut {
  phone      String   @id
  optedOutAt DateTime @default(now()) @map("opted_out_at")
  source     String   @default("STOP")

  @@map("sms_opt_out")
}

// Clerk webhook audit. Distinct from audit_events (which is the application
// audit log). auth_events is replay-able + idempotent: webhook handler
// upserts on (event_type, payload->>'id') to handle Svix retries.
model AuthEvent {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String?         @map("tenant_id") @db.Uuid
  userId      String?         @map("user_id")
  eventType   String          @map("event_type")
  payload     Json
  receivedAt  DateTime        @default(now()) @map("received_at")
  processedAt DateTime?       @map("processed_at")
  status      AuthEventStatus @default(received)
  errorMsg    String?         @map("error_msg")

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([eventType, receivedAt])
  @@map("auth_events")
}

// Worker profile — extends User for the `worker` role. PK == User.id.
// See docs/10-worker/01-onboarding/02-data-model.md.
model WorkerProfile {
  id             String        @id // matches User.id (Clerk userId)
  firstName      String        @map("first_name")
  lastName       String        @map("last_name")
  zipCode        String?       @map("zip_code")
  county         County?
  skills         String[]      @default([])
  certifications Json          @default("[]")
  availability   Json          @default("{}")
  resume         Json?
  resumeRawUrl   String?       @map("resume_raw_url")
  parserStatus   ParserStatus? @map("parser_status")
  phoneHash      String?       @map("phone_hash")
  onboardedAt    DateTime?     @map("onboarded_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  @@index([county])
  @@index([phoneHash])
  @@map("worker_profiles")
}

// Job postings created by employers. SEO slug-routed for crawlable URLs.
// See docs/20-employer/02-job-postings (referenced by 10-worker/03-job-discovery).
model JobPosting {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  employerId     String    @map("employer_id")
  titleEn        String    @map("title_en")
  titleEs        String    @map("title_es")
  descriptionEn  String    @map("description_en")
  descriptionEs  String    @map("description_es")
  county         County
  city           String?
  zipCode        String?   @map("zip_code")
  wageMin        Decimal   @map("wage_min") @db.Decimal(8, 2)
  wageMax        Decimal   @map("wage_max") @db.Decimal(8, 2)
  wageUnit       WageUnit  @default(hour) @map("wage_unit")
  startDate      DateTime  @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  applyBy        DateTime? @map("apply_by") @db.Date
  skills         String[]  @default([])
  housing        Boolean   @default(false)
  transport      Boolean   @default(false)
  positionsTotal Int       @default(1) @map("positions_total")
  hireCount      Int       @default(0) @map("hire_count")
  status         JobStatus @default(draft)
  seoSlug        String?   @unique @map("seo_slug") // null for drafts; set at publish
  publishedAt    DateTime? @map("published_at")
  filledAt       DateTime? @map("filled_at")
  closedAt       DateTime? @map("closed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  // ── Edit-Job v2 spec ──
  cropId                String?       @map("crop_id") @db.Uuid
  roleTypeId            String?       @map("role_type_id") @db.Uuid
  dailyStartTime        DateTime?     @map("daily_start_time") @db.Time(0)
  dailyEndTime          DateTime?     @map("daily_end_time") @db.Time(0)
  workingDays           Int           @default(31) @map("working_days") @db.SmallInt
  wageStructure         WageStructure @default(hourly) @map("wage_structure")
  pieceRate             Decimal?      @map("piece_rate") @db.Decimal(8, 4)
  pieceUnit             String?       @map("piece_unit")
  payFrequency          PayFrequency  @default(weekly) @map("pay_frequency")
  mealsProvided         Boolean       @default(false) @map("meals_provided")
  endOfSeasonBonusCents Int?          @map("end_of_season_bonus_cents")
  pickupPoint           String?       @map("pickup_point")
  minExperience         MinExperience @default(none) @map("min_experience")
  minAge                MinAge        @default(eighteen) @map("min_age")
  autoMatchEnabled      Boolean       @default(true) @map("auto_match_enabled")
  autoTranslateEnabled  Boolean       @default(true) @map("auto_translate_enabled")
  renotifyPaused        Boolean       @default(false) @map("renotify_paused")
  smsApplyEnabled       Boolean       @default(true) @map("sms_apply_enabled")
  smsApplyKeyword       String?       @map("sms_apply_keyword")
  applicationDeadlineAt DateTime?     @map("application_deadline_at")
  foremanContactId      String?       @map("foreman_contact_id") @db.Uuid
  siteAddress           String?       @map("site_address")
  siteAcres             Decimal?      @map("site_acres") @db.Decimal(8, 2)
  siteLat               Float?        @map("site_lat")
  siteLng               Float?        @map("site_lng")
  humanId               String?       @map("human_id")
  lastEditedById        String?       @map("last_edited_by_id")
  autosavedAt           DateTime?     @map("autosaved_at")

  tenant             Tenant                 @relation(fields: [tenantId], references: [id])
  employer           User                   @relation("JobPostingEmployer", fields: [employerId], references: [id])
  lastEditedBy       User?                  @relation("JobPostingLastEditor", fields: [lastEditedById], references: [id])
  crop               Crop?                  @relation(fields: [cropId], references: [id])
  roleType           RoleType?              @relation(fields: [roleTypeId], references: [id])
  foremanContact     EmployerContact?       @relation(fields: [foremanContactId], references: [id])
  applications       Application[]
  workerInvitations  WorkerInvitation[]
  photos             JobPhoto[]
  screeningQuestions JobScreeningQuestion[]
  editEvents         JobEditEvent[]
  renotifications    JobRenotification[]

  @@index([tenantId])
  @@index([tenantId, status, county])
  @@index([status, startDate])
  @@index([employerId, status])
  @@index([cropId])
  @@index([roleTypeId])
  @@map("job_postings")
}

// Worker application to a job. UNIQUE(jobId, workerId) backstops dual-apply.
// See docs/10-worker/04-application-tracker/02-data-model.md and
// docs/20-employer/03-applicant-review/02-data-model.md (employer-side fields).
model Application {
  id                  String           @id @default(uuid()) @db.Uuid
  tenantId            String           @map("tenant_id") @db.Uuid
  jobId               String           @map("job_id") @db.Uuid
  workerId            String           @map("worker_id")
  status              AppStatus        @default(applied)
  wageOffered         Decimal?         @map("wage_offered") @db.Decimal(8, 2)
  workerNote          String?          @map("worker_note") @db.VarChar(500)
  employerNote        String?          @map("employer_note") @db.VarChar(2000) // private to employer
  rejectionReason     RejectionReason? @map("rejection_reason")
  rejectionReasonText String?          @map("rejection_reason_text") @db.VarChar(500)
  appliedAt           DateTime         @default(now()) @map("applied_at")
  reviewedAt          DateTime?        @map("reviewed_at")
  hiredAt             DateTime?        @map("hired_at")
  rejectedAt          DateTime?        @map("rejected_at")
  withdrawnAt         DateTime?        @map("withdrawn_at")
  startDate           DateTime?        @map("start_date") @db.Date
  countyAtApply       County?          @map("county_at_apply")
  skillsAtApply       String[]         @default([]) @map("skills_at_apply")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  deletedAt           DateTime?        @map("deleted_at")

  tenant           Tenant                       @relation(fields: [tenantId], references: [id])
  job              JobPosting                   @relation(fields: [jobId], references: [id])
  worker           User                         @relation(fields: [workerId], references: [id])
  events           ApplicationEvent[]
  screeningAnswers ApplicationScreeningAnswer[]
  renotifications  JobRenotification[]

  @@unique([jobId, workerId])
  @@index([tenantId])
  @@index([workerId, status])
  @@index([jobId, status])
  @@index([appliedAt])
  @@map("applications")
}

model ApplicationEvent {
  id            String     @id @default(uuid()) @db.Uuid
  tenantId      String     @map("tenant_id") @db.Uuid
  applicationId String     @map("application_id") @db.Uuid
  fromStatus    AppStatus? @map("from_status")
  toStatus      AppStatus  @map("to_status")
  actorUserId   String     @map("actor_user_id")
  actorRole     UserRole   @map("actor_role")
  metadata      Json       @default("{}")
  createdAt     DateTime   @default(now()) @map("created_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([applicationId, createdAt])
  @@map("application_events")
}

// Saved searches with optional SMS / email alerts.
// See docs/10-worker/03-job-discovery/02-data-model.md.
model SavedSearch {
  id             String       @id @default(uuid()) @db.Uuid
  workerId       String       @map("worker_id")
  name           String?
  filters        Json
  alertChannel   AlertChannel @default(sms) @map("alert_channel")
  alertActive    Boolean      @default(true) @map("alert_active")
  lastNotifiedAt DateTime?    @map("last_notified_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  worker User @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@index([alertActive])
  @@map("saved_searches")
}

// Lightweight per-search analytics for "what are workers searching for"
// admin reports + zero-result detection.
model SearchView {
  id          String   @id @default(uuid()) @db.Uuid
  workerId    String?  @map("worker_id")
  filters     Json
  resultCount Int      @map("result_count")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([workerId, createdAt])
  @@map("search_views")
}

// Training programs run by training_org users. Bilingual fields.
// See docs/10-worker/05-training-browser/02-data-model.md.
model TrainingProgram {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  orgId           String        @map("org_id")
  titleEn         String        @map("title_en")
  titleEs         String        @map("title_es")
  summaryEn       String?       @map("summary_en") @db.VarChar(280)
  summaryEs       String?       @map("summary_es") @db.VarChar(280)
  descriptionEn   String        @map("description_en")
  descriptionEs   String        @map("description_es")
  funder          Funder
  county          County
  locationName    String        @map("location_name")
  locationAddress String        @map("location_address")
  capacity        Int
  enrolledCount   Int           @default(0) @map("enrolled_count")
  startDate       DateTime      @map("start_date")
  endDate         DateTime      @map("end_date")
  sessionTimes    Json          @default("[]") @map("session_times")
  topics          String[]      @default([])
  certName        String?       @map("cert_name")
  seoSlug         String        @unique @map("seo_slug")
  status          ProgramStatus @default(draft)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  org         User         @relation("TrainingProgramOrg", fields: [orgId], references: [id])
  enrollments Enrollment[]

  @@index([tenantId])
  @@index([county])
  @@index([funder])
  @@index([status, startDate])
  @@map("training_programs")
}

model Enrollment {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  programId       String           @map("program_id") @db.Uuid
  workerId        String           @map("worker_id")
  status          EnrollmentStatus @default(enrolled)
  enrolledAt      DateTime         @default(now()) @map("enrolled_at")
  completedAt     DateTime?        @map("completed_at")
  droppedAt       DateTime?        @map("dropped_at")
  certUrl         String?          @map("cert_url")
  certGeneratedAt DateTime?        @map("cert_generated_at")
  certificateId   String?          @unique @map("certificate_id")
  noShow          Boolean          @default(false) @map("no_show")
  reminderSent48h Boolean          @default(false) @map("reminder_sent_48h")
  reminderSent2h  Boolean          @default(false) @map("reminder_sent_2h")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  tenant  Tenant          @relation(fields: [tenantId], references: [id])
  program TrainingProgram @relation(fields: [programId], references: [id])
  worker  User            @relation(fields: [workerId], references: [id])

  @@unique([programId, workerId])
  @@index([tenantId])
  @@index([workerId, status])
  @@index([programId, status])
  @@map("enrollments")
}

// Crew = stable group of workers that move together across shifts.
// See docs/20-employer/06-crews-shifts/02-data-model.md.
model Crew {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  employerId          String    @map("employer_id")
  foremanUserId       String?   @map("foreman_user_id")
  jobId               String?   @map("job_id") @db.Uuid
  name                String
  shortCode           String?   @map("short_code") @db.VarChar(8)
  crewType            String?   @map("crew_type") @db.VarChar(32)
  primaryCrop         String?   @map("primary_crop") @db.VarChar(32)
  color               String    @default("olive")
  requiredSkills      String[]  @default([]) @map("required_skills")
  baseWageCents       Int?      @map("base_wage_cents")
  pieceRateCents      Int?      @map("piece_rate_cents")
  pieceRateUnit       String?   @map("piece_rate_unit") @db.VarChar(16)
  foremanPremiumCents Int?      @map("foreman_premium_cents")
  commsChannels       Json      @default("{}") @map("comms_channels")
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  tenant   Tenant       @relation(fields: [tenantId], references: [id])
  employer User         @relation("CrewEmployer", fields: [employerId], references: [id])
  foreman  User?        @relation("CrewForeman", fields: [foremanUserId], references: [id])
  members  CrewMember[]
  shifts   Shift[]

  @@index([tenantId])
  @@index([employerId])
  @@index([foremanUserId])
  @@map("crews")
}

model CrewMember {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  crewId       String         @map("crew_id") @db.Uuid
  workerUserId String         @map("worker_user_id")
  role         CrewMemberRole @default(member)
  joinedAt     DateTime       @default(now()) @map("joined_at")
  leftAt       DateTime?      @map("left_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  crew   Crew   @relation(fields: [crewId], references: [id], onDelete: Cascade)
  worker User   @relation(fields: [workerUserId], references: [id])

  @@index([tenantId])
  @@index([crewId])
  @@index([workerUserId])
  @@map("crew_members")
}

// Shift = single dated work block tied to a crew (or ad-hoc when crew is null).
// See docs/20-employer/06-crews-shifts/02-data-model.md.
model Shift {
  id            String      @id @default(uuid()) @db.Uuid
  tenantId      String      @map("tenant_id") @db.Uuid
  employerId    String      @map("employer_id")
  crewId        String?     @map("crew_id") @db.Uuid
  jobId         String?     @map("job_id") @db.Uuid
  shiftDate     DateTime    @map("shift_date") @db.Date
  startTime     String      @map("start_time") // 'HH:MM' local
  endTime       String?     @map("end_time")
  locationLabel String      @map("location_label")
  locationLat   Decimal?    @map("location_lat") @db.Decimal(9, 6)
  locationLng   Decimal?    @map("location_lng") @db.Decimal(9, 6)
  status        ShiftStatus @default(scheduled)
  shiftType     ShiftType   @default(work) @map("shift_type")
  metadata      Json        @default("{}")
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  employer    User              @relation("ShiftEmployer", fields: [employerId], references: [id])
  crew        Crew?             @relation(fields: [crewId], references: [id])
  assignments ShiftAssignment[]

  @@index([tenantId])
  @@index([employerId, shiftDate])
  @@index([crewId, shiftDate])
  @@index([status])
  @@index([shiftType])
  @@map("shifts")
}

model ShiftAssignment {
  id             String                @id @default(uuid()) @db.Uuid
  tenantId       String                @map("tenant_id") @db.Uuid
  shiftId        String                @map("shift_id") @db.Uuid
  workerUserId   String                @map("worker_user_id")
  status         ShiftAssignmentStatus @default(assigned)
  hoursWorked    Decimal?              @map("hours_worked") @db.Decimal(5, 2)
  piecesCount    Int?                  @map("pieces_count")
  pieceRateCents Int?                  @map("piece_rate_cents")
  arrivedAt      DateTime?             @map("arrived_at")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shift  Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  worker User   @relation(fields: [workerUserId], references: [id])

  @@unique([shiftId, workerUserId])
  @@index([tenantId])
  @@index([workerUserId, shiftId])
  @@index([status])
  @@map("shift_assignments")
}

// Payroll period — bounded date range with aggregated line items.
// See docs/20-employer/07-payroll/02-data-model.md.
model PayrollPeriod {
  id           String              @id @default(uuid()) @db.Uuid
  tenantId     String              @map("tenant_id") @db.Uuid
  employerId   String              @map("employer_id")
  startDate    DateTime            @map("start_date") @db.Date
  endDate      DateTime            @map("end_date") @db.Date
  payDate      DateTime            @map("pay_date") @db.Date
  status       PayrollPeriodStatus @default(draft)
  approvedAt   DateTime?           @map("approved_at")
  approvedById String?             @map("approved_by_id")
  paidAt       DateTime?           @map("paid_at")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  employer   User          @relation("PayrollEmployer", fields: [employerId], references: [id])
  approvedBy User?         @relation("PayrollApprover", fields: [approvedById], references: [id])
  lines      PayrollLine[]

  @@index([tenantId])
  @@index([employerId, startDate])
  @@index([status])
  @@map("payroll_periods")
}

model PayrollLine {
  id                    String    @id @default(uuid()) @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  periodId              String    @map("period_id") @db.Uuid
  workerUserId          String    @map("worker_user_id")
  role                  String?
  hours                 Decimal   @default(0) @db.Decimal(6, 2)
  overtimeHours         Decimal   @default(0) @map("overtime_hours") @db.Decimal(6, 2)
  nonProductiveHours    Decimal   @default(0) @map("non_productive_hours") @db.Decimal(6, 2)
  restPeriodHours       Decimal   @default(0) @map("rest_period_hours") @db.Decimal(6, 2)
  regularPayCents       Int       @default(0) @map("regular_pay_cents")
  overtimePayCents      Int       @default(0) @map("overtime_pay_cents")
  pieceRatePayCents     Int       @default(0) @map("piece_rate_pay_cents")
  nonProductivePayCents Int       @default(0) @map("non_productive_pay_cents")
  restPeriodPayCents    Int       @default(0) @map("rest_period_pay_cents")
  aewrTopUpCents        Int       @default(0) @map("aewr_top_up_cents")
  appliedFloorCents     Int       @default(0) @map("applied_floor_cents")
  isH2a                 Boolean   @default(false) @map("is_h2a")
  grossCents            Int       @default(0) @map("gross_cents")
  bonusCents            Int       @default(0) @map("bonus_cents")
  taxesCents            Int       @default(0) @map("taxes_cents")
  netCents              Int       @default(0) @map("net_cents")
  notes                 String?
  approvedAt            DateTime? @map("approved_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  period PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  worker User          @relation(fields: [workerUserId], references: [id])

  @@unique([periodId, workerUserId])
  @@index([tenantId])
  @@index([workerUserId])
  @@map("payroll_lines")
}

// Federal H-2A Adverse Effect Wage Rate by state. Platform-level reference
// data (no tenant_id). Updated annually by USDOL ETA. Lookup is by state +
// effective date range.
model AewrRate {
  id            String    @id @default(uuid()) @db.Uuid
  stateCode     String    @map("state_code") @db.VarChar(2)
  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  hourlyCents   Int       @map("hourly_cents")
  source        String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([stateCode, effectiveFrom])
  @@index([stateCode, effectiveFrom])
  @@map("aewr_rates")
}

// Compliance — flat item registry per employer.
// See docs/20-employer/08-compliance/02-data-model.md.
model ComplianceItem {
  id                  String               @id @default(uuid()) @db.Uuid
  tenantId            String               @map("tenant_id") @db.Uuid
  employerId          String               @map("employer_id")
  category            String // 'documentation', 'safety', 'wage_hour', 'pesticide', 'h2a', custom
  itemKey             String               @map("item_key")
  label               String
  status              ComplianceItemStatus @default(ok)
  details             String?
  evidenceUrl         String?              @map("evidence_url")
  evidenceStorageKey  String?              @map("evidence_storage_key")
  evidenceFileName    String?              @map("evidence_file_name")
  evidenceContentType String?              @map("evidence_content_type")
  evidenceSize        Int?                 @map("evidence_size")
  dueAt               DateTime?            @map("due_at")
  resolvedAt          DateTime?            @map("resolved_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  employer User   @relation("ComplianceEmployer", fields: [employerId], references: [id])

  @@unique([employerId, category, itemKey])
  @@index([tenantId])
  @@index([employerId, status])
  @@index([dueAt])
  @@map("compliance_items")
}

// Bilingual instructional content shown in the compliance modal sidebar.
// One row per `ComplianceItem.itemKey`. JSONB matches the TypeScript
// `ComplianceItemContent` shape: { why, how, acceptableEvidence, deadline,
// source, extraSources?, lastVerified }. Owned by compliance ops via the
// admin surface (not by engineers).
model ComplianceItemContent {
  itemKey     String   @id @map("item_key")
  content     Json
  publishedAt DateTime @default(now()) @map("published_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id")

  @@map("compliance_item_content")
}

// Periodic snapshot of overall compliance score per employer profile.
// Written daily (idempotent on (employerProfileId, snapshotDate)) so the
// compliance dashboard can compute real "vs. last quarter" deltas instead
// of hardcoded copy.
model ComplianceScoreSnapshot {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  employerProfileId String   @map("employer_profile_id") @db.Uuid
  snapshotDate      DateTime @map("snapshot_date") @db.Date
  score             Int
  okCount           Int      @default(0) @map("ok_count")
  warnCount         Int      @default(0) @map("warn_count")
  failCount         Int      @default(0) @map("fail_count")
  createdAt         DateTime @default(now()) @map("created_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  employerProfile EmployerProfile @relation(fields: [employerProfileId], references: [id])

  @@unique([employerProfileId, snapshotDate])
  @@index([tenantId])
  @@index([employerProfileId, snapshotDate])
  @@map("compliance_score_snapshots")
}

// In-app messaging — SMS/WhatsApp use existing sms package; this is the
// per-conversation/per-message log + thread index for the messages UI.
// See docs/20-employer/09-messaging/02-data-model.md.
model Conversation {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  employerId    String         @map("employer_id")
  title         String
  isGroup       Boolean        @default(false) @map("is_group")
  channel       MessageChannel @default(app)
  pinnedShiftId String?        @map("pinned_shift_id") @db.Uuid
  lastMessageAt DateTime?      @map("last_message_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")

  tenant       Tenant                    @relation(fields: [tenantId], references: [id])
  employer     User                      @relation("ConversationEmployer", fields: [employerId], references: [id])
  participants ConversationParticipant[]
  messages     Message[]

  @@index([tenantId])
  @@index([employerId, lastMessageAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  userId         String    @map("user_id")
  joinedAt       DateTime  @default(now()) @map("joined_at")
  leftAt         DateTime? @map("left_at")
  unreadCount    Int       @default(0) @map("unread_count")
  lastReadAt     DateTime? @map("last_read_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid
  conversationId String           @map("conversation_id") @db.Uuid
  senderUserId   String           @map("sender_user_id")
  body           String
  channel        MessageChannel   @default(app)
  direction      MessageDirection @default(outbound)
  smsLogId       String?          @map("sms_log_id") @db.Uuid
  metadata       Json             @default("{}")
  createdAt      DateTime         @default(now()) @map("created_at")
  deletedAt      DateTime?        @map("deleted_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderUserId], references: [id])

  @@index([tenantId])
  @@index([conversationId, createdAt])
  @@index([senderUserId])
  @@map("messages")
}

// ============================================================================
// TranslationKey — DB-backed UI copy.
//
// The single source of truth for all UI copy. Replaces apps/web/messages/{en,es}.json.
// next-intl loads messages from this table at request time, cached via
// unstable_cache with revalidate-tag so admin edits propagate within ~5 min.
//
// Tenant override resolution: rows with tenantId = NULL are global defaults.
// Rows with a specific tenantId override the global default for that tenant
// (same namespace + key + locale). Resolved at load time, not at write time.
//
// Edge runtime carve-out: /og/landing and any other edge-runtime route uses
// env-var-or-literal for brand primitives (product_name, hero headline) and
// does NOT call this table. Document new edge routes the same way.
//
// See docs/00-foundation/04-i18n/02-data-model.md for the full pattern.
// ============================================================================
model TranslationKey {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String?           @map("tenant_id") @db.Uuid
  namespace   String // e.g. "marketing.faq_page", "landing.hero"
  key         String // dot-path within namespace, e.g. "headline", "tile.workersPlaced.label"
  locale      Lang
  value       String            @db.Text
  status      TranslationStatus @default(published)
  reviewedBy  String?           @map("reviewed_by")
  reviewedAt  DateTime?         @map("reviewed_at")
  publishedAt DateTime?         @map("published_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // NOTE: uniqueness on (tenant_id, namespace, key, locale) is enforced by
  // partial indexes in the migration SQL (translation_keys_global_unique,
  // translation_keys_tenant_unique). Prisma doesn't model partial indexes,
  // so this constraint lives at the SQL layer only. Don't add @@unique here.
  @@index([tenantId, locale])
  @@index([namespace, locale])
  @@map("translation_keys")
}

enum TranslationStatus {
  draft
  needs_review
  reviewed
  published
}

