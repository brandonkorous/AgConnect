{
  "name": "@agconn/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "i18n:seed": "tsx scripts/seed-translations.ts",
    "i18n:check": "tsx scripts/check-i18n-parity.ts",
    "lookups:seed": "tsx scripts/seed-lookups.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "8.20.0",
    "dotenv": "17.4.2",
    "prisma": "7.8.0",
    "tsx": "^4.19.0",
    "typescript": "6.0.3"
  }
}
