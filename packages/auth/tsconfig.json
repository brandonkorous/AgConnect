{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "jsx": "react-jsx",
        "module": "Preserve",
        "moduleResolution": "Bundler",
        "outDir": "./dist",
        "rootDir": "./src",
        "declaration": true,
        "types": ["node", "react"],
        "noEmit": false
    },
    "include": ["src/**/*.ts", "src/**/*.tsx"],
    "exclude": ["node_modules", "dist"]
}
