{
  "name": "@agconn/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./src/server.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./src/client.ts"
    },
    "./react": {
      "import": "./dist/provider.js",
      "types": "./src/provider.tsx"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "19.2.5"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "hono": "4.12.15",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "react": "19.2.5",
    "typescript": "6.0.3"
  }
}
