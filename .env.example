# Public — exposed to the browser. Use only for non-secret config.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# API
API_BASE_URL=http://localhost:3001
PORT=3001
PUBLIC_WEB_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:3001

# Multi-tenancy — UUID of the default tenant for /v1/landing/* (unauthenticated
# marketing surfaces). Seeded by the rls_and_seed migration.
PUBLIC_TENANT_ID=aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa

# Database (packages/db, services/api, services/email-worker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agconn?schema=public

# Resend (server-only)
RESEND_API_KEY=
RESEND_FROM_EMAIL="AgConn <hello@agconn.com>"
# Resend webhook signing secret (Svix). Set after creating the endpoint in Resend dashboard.
RESEND_WEBHOOK_SECRET=

# Waitlist confirm/unsubscribe JWT signing — random string, 32+ characters.
# openssl rand -base64 48
WAITLIST_TOKEN_SECRET=

# Audit log integrity (packages/audit, services/api, services/audit-*).
# Required: services boot fail loudly without it. Generate with:
#   openssl rand -base64 48
# Production: pulled from Azure Key Vault via CSI driver, NOT committed.
AUDIT_HMAC_KEY=
AUDIT_HMAC_KEY_VERSION=1
# Optional: prior key versions still needed to verify older rows. JSON array
# of { v: number, k: string (base64) }, e.g. AUDIT_HMAC_KEYS_PRIOR='[{"v":1,"k":"..."}]'
AUDIT_HMAC_KEYS_PRIOR=

# Admin bearer token — MVP gate for /admin/v1/*. Kept as fallback alongside
# the Clerk admin role check. Generate with: openssl rand -hex 32
ADMIN_BEARER_TOKEN=

# Clerk auth (apps/web + services/api). Empty = auth disabled in dev,
# everything falls through to public + the bearer admin gate. Get keys at
# dashboard.clerk.com → API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook signing secret from Clerk dashboard → Webhooks endpoint.
CLERK_WEBHOOK_SECRET=
# Sign-in / sign-up URLs (locale-prefixed). Override per-locale at runtime.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/en/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/en/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/en
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/en

# Sentry error monitoring + tracing + session replay.
# DSNs come from sentry.io project settings. Leave empty in dev to disable.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Source map upload — auth token from sentry.io/settings/auth-tokens/
# scopes: project:releases, org:read. Set in CI secrets, not committed.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Optional environment tag. Defaults to NODE_ENV.
APP_ENV=
NEXT_PUBLIC_APP_ENV=

# PostHog analytics + feature flags + session replay (browser side).
# Project from posthog.com → Project settings. Leave empty to disable.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side PostHog (feature flags evaluated server-side, server-emitted events).
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Twilio SMS (services/sms-worker, services/api Twilio webhooks).
# A2P 10DLC registration is required for US sending — start the carrier review
# 1–4 weeks before launch. Leave TWILIO_ACCOUNT_SID empty to dry-run sends
# (sms_log + audit still record; nothing leaves the cluster).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Messaging Service SID (MGxxxxxxxx). Pools senders + handles 10DLC + STOP
# auto-replies. Required for non-dry-run sends.
TWILIO_MESSAGING_SERVICE_SID=
# Set TWILIO_DRY_RUN=1 to force dry-run even with a real SID configured.
TWILIO_DRY_RUN=
