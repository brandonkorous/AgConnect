# Public — exposed to the browser. Use only for non-secret config.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# API
API_BASE_URL=http://localhost:3001
PORT=3001
PUBLIC_WEB_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:3001

# Database (packages/db, services/api, services/email-worker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agconn?schema=public

# Resend (server-only)
RESEND_API_KEY=
RESEND_FROM_EMAIL="AgConn <hello@agconn.com>"
# Resend webhook signing secret (Svix). Set after creating the endpoint in Resend dashboard.
RESEND_WEBHOOK_SECRET=

# Waitlist confirm/unsubscribe JWT signing — random string, 32+ characters.
# Read by services/api (landing routes) and services/email-worker; both MUST
# share the same value or signed links won't verify. Rotating invalidates every
# unredeemed waitlist email link in flight.
# Generate with one of:
#   PowerShell: $b = New-Object byte[] 48; [Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($b); [Convert]::ToBase64String($b)
#   OpenSSL:    openssl rand -base64 48
#   Node:       node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
WAITLIST_TOKEN_SECRET=

# Audit log integrity (packages/audit, services/api, services/audit-*).
# Required: services boot fail loudly without it. Generate with:
#   openssl rand -base64 48
# Production: stored as a GitHub Actions secret, projected into the K8s
# `agconn-env` Secret by the deploy workflow. NOT committed.
AUDIT_HMAC_KEY=
AUDIT_HMAC_KEY_VERSION=1
# Optional: prior key versions still needed to verify older rows. JSON array
# of { v: number, k: string (base64) }, e.g. AUDIT_HMAC_KEYS_PRIOR='[{"v":1,"k":"..."}]'
AUDIT_HMAC_KEYS_PRIOR=

# Admin bearer token — MVP gate for /admin/v1/*. Kept as fallback alongside
# the Clerk admin role check. Generate with: openssl rand -hex 32
ADMIN_BEARER_TOKEN=

# Participant ID pepper for WIOA / CalJOBS placement-report exports.
# Hashed with (tenantId, workerId) to produce stable anonymized participant IDs
# in the form P-XXXXXXXXXXXX. Generate with: openssl rand -hex 32
# Production: stored as a GitHub Actions secret, projected into the K8s
# `agconn-env` Secret by the deploy workflow. NOT committed.
#
# IMPORTANT: this secret is *immutable* once set. Rotating it changes every
# previously-issued participant ID, breaking longitudinal tracking for grantees.
# Treat it like a primary key — pick once, document, never change.
# See docs/30-admin/02-placement-report/08-edge-cases.md.
PARTICIPANT_PEPPER=

# Clerk auth (apps/web + services/api). Empty = auth disabled in dev,
# everything falls through to public + the bearer admin gate. Get keys at
# dashboard.clerk.com → API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook signing secret from Clerk dashboard → Webhooks endpoint.
CLERK_WEBHOOK_SECRET=
# Sign-in / sign-up URLs (locale-prefixed). Override per-locale at runtime.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/en/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/en/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/en
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/en

# Sentry error monitoring + tracing + session replay.
# DSNs come from sentry.io project settings. Leave empty in dev to disable.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Source map upload — auth token from sentry.io/settings/auth-tokens/
# scopes: project:releases, org:read. Set in CI secrets, not committed.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Optional environment tag. Defaults to NODE_ENV.
APP_ENV=
NEXT_PUBLIC_APP_ENV=

# PostHog analytics + feature flags + session replay (browser side).
# Project from posthog.com → Project settings. Leave empty to disable.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side PostHog (feature flags evaluated server-side, server-emitted events).
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Stripe billing (services/api employer/billing/* + webhooks/stripe).
# When STRIPE_SECRET_KEY is empty, /v1/employer/billing/checkout returns
# stripe_unavailable; the billing UI shows the warning banner. STRIPE_PRICE_*
# values come from dashboard.stripe.com → Products. Leave empty for any tier
# you haven't priced yet — that tier's "Upgrade" button will surface the
# stripe_unavailable error rather than failing silently.
#
# Eight paid price IDs total: tier (PRO=Field, ENT=Farm) × interval (MONTHLY,
# YEARLY) × cohort (standard, FOUNDER). The first 50 paid accounts across
# Field+Farm combined receive founder pricing; checkout resolves the cohort
# live from the founder-slots count. See
# docs/20-employer/05-subscription-billing/01-overview.md.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Standard pricing (account 51+)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ENT_MONTHLY=
STRIPE_PRICE_ENT_YEARLY=
# Founder pricing (accounts 1–50)
STRIPE_PRICE_PRO_FOUNDER_MONTHLY=
STRIPE_PRICE_PRO_FOUNDER_YEARLY=
STRIPE_PRICE_ENT_FOUNDER_MONTHLY=
STRIPE_PRICE_ENT_FOUNDER_YEARLY=
# Web URL Stripe redirects back to after checkout / portal sessions.
WEB_URL=http://localhost:3000

# Twilio SMS (services/sms-worker, services/api Twilio webhooks).
# A2P 10DLC registration is required for US sending — start the carrier review
# 1–4 weeks before launch. Leave TWILIO_ACCOUNT_SID empty to dry-run sends
# (sms_log + audit still record; nothing leaves the cluster).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Messaging Service SID (MGxxxxxxxx). Pools senders + handles 10DLC + STOP
# auto-replies. Required for non-dry-run sends.
TWILIO_MESSAGING_SERVICE_SID=
# Set TWILIO_DRY_RUN=1 to force dry-run even with a real SID configured.
TWILIO_DRY_RUN=
# SMS-apply inbound number — workers text APPLY-* keywords here. Distinct from
# the messaging-service SID; this is a single long-code or short-code number.
TWILIO_INBOUND_PHONE=

# Supabase Storage (services/api photo uploads). Service-role key — never
# exposed to the browser. Bucket names are code-controlled (see
# services/api/src/lib/supabase-storage.ts BUCKETS). Tenancy is enforced at
# the path-prefix layer (`<tenantId>/<jobId>/<file>`) plus Storage RLS.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox public token (Search Box autocomplete + Geocoding reverse-lookup, browser).
# Use the same `pk.` token from account.mapbox.com. Restrict it to your origins
# (production domain + http://localhost:3000) under Mapbox dashboard → Tokens →
# URL allowlist. Free tier: 100k req/month.
NEXT_PUBLIC_MAPBOX_TOKEN=
