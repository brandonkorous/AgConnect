{
  "name": "agconn",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.9.0"
  },
  "packageManager": "pnpm@10.9.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @agconn/web dev",
    "dev:api": "pnpm --filter @agconn/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint && pnpm check:conventions",
    "typecheck": "pnpm -r typecheck && pnpm check:conventions",
    "check:conventions": "node scripts/check-tenant-id.mjs && node scripts/check-rls.mjs && node scripts/check-audit-required.mjs && node scripts/check-sms.mjs",
    "check:tenant-id": "node scripts/check-tenant-id.mjs",
    "check:rls": "node scripts/check-rls.mjs",
    "check:audit-required": "node scripts/check-audit-required.mjs",
    "check:sms": "node scripts/check-sms.mjs",
    "db:generate": "pnpm --filter @agconn/db db:generate",
    "db:push": "pnpm --filter @agconn/db db:push",
    "db:migrate:dev": "pnpm --filter @agconn/db db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @agconn/db db:migrate:deploy",
    "db:studio": "pnpm --filter @agconn/db db:studio",
    "email:dev": "pnpm --filter @agconn/email email:dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,yml,yaml}\""
  }
}
